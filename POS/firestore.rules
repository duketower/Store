rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Audit collections — immutable once written.
    match /sales/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }
    match /credit_ledger/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }
    match /errors/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }

    // Mutable collections.
    match /products/{id}     { allow read, write: if request.auth != null; }
    match /batches/{id}      { allow read, write: if request.auth != null; }
    match /customers/{id}    { allow read, write: if request.auth != null; }
    match /employees/{id}    { allow read, write: if request.auth != null; }
    match /day_sessions/{id} { allow read, write: if request.auth != null; }
    match /outbox/{id}       { allow read, write: if request.auth != null; }

    // Global counters (bill number deduplication across devices).
    match /counters/{id}     { allow read, write: if request.auth != null; }
  }
}
