rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Audit collections — immutable once written.
    match /sales/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }
    match /sale_returns/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }
    match /credit_ledger/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }
    match /errors/{id} {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }

    // Mutable collections.
    match /products/{id}     { allow read, write: if request.auth != null; }
    match /batches/{id}      { allow read, write: if request.auth != null; }
    match /customers/{id}    { allow read, write: if request.auth != null; }
    match /vendors/{id}      { allow read, write: if request.auth != null; }
    match /grns/{id}         { allow read, write: if request.auth != null; }
    match /rtvs/{id}         { allow read, write: if request.auth != null; }
    match /staff_external/{id} { allow read, write: if request.auth != null; }
    match /attendance_logs/{id} { allow read, write: if request.auth != null; }
    match /leave_requests/{id} { allow read, write: if request.auth != null; }
    match /day_sessions/{id} { allow read, write: if request.auth != null; }
    match /cash_entries/{id} { allow read, write: if request.auth != null; }
    match /expenses/{id}     { allow read, write: if request.auth != null; }
    match /app_settings/{id} { allow read, write: if request.auth != null; }
    match /outbox/{id}       { allow read, write: if request.auth != null; }

    // Employee records — credential hashes (passwordHash, pinHash) are stripped before syncing
    // (see migration.ts). Only name, role, isActive are stored here for cross-device visibility.
    // Write access is intentionally kept so the migration can push initial records.
    match /employees/{id}    { allow read, write: if request.auth != null; }

    // Global counters (bill number deduplication across devices).
    match /counters/{id}     { allow read, write: if request.auth != null; }
  }
}
